# Public hostname and ACME contact. DNS must point to the VM before Caddy starts.
KEIVO_DOMAIN=keivo.example.com
ACME_EMAIL=admin@example.com

# HTTP Basic Auth. Keep the generated bcrypt hash single-quoted so $ stays literal.
KEIVO_AUTH_USER=keivo-admin
KEIVO_AUTH_HASH='REPLACE_WITH_CADDY_BCRYPT_HASH'

# Override this value to pull and run another Ollama model.
OLLAMA_MODEL=qwen3:8b
OLLAMA_IMAGE_TAG=latest
OLLAMA_KEEP_ALIVE=10m
OLLAMA_THINK=true

# Optional generation limits.
AGENT_MAX_OUTPUT_TOKENS=8192
AGENT_CONTEXT_WINDOW=32768
AGENT_TEMPERATURE=0.55
AGENT_MAX_INPUT_CHARS=24000
AGENT_REQUEST_TIMEOUT=600

# Protect local inference capacity. Blocked users receive an exact retry time.
AGENT_USAGE_LIMIT_PER_HOUR=60
